{
  "name": "promo-reel-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Auto-generates Bojan Petkovic promo reel video from slot game capture + brand overlay. Single-command pipeline: capture → detect → cut → brand → MP4.",
  "scripts": {
    "simulate": "node record-simulator.mjs",
    "make": "node src/make-reel.mjs",
    "make:vertical": "node src/make-reel.mjs --format=vertical",
    "make:landscape": "node src/make-reel.mjs --format=landscape",
    "make:both": "node src/make-reel.mjs --format=both",
    "capture": "node src/capture.mjs",
    "compose": "node src/compose.mjs",
    "brand": "node src/brand-assets.mjs",
    "clean": "rm -rf output/* captures/raw-*.mp4"
  },
  "dependencies": {
    "playwright": "^1.59.1"
  }
}
